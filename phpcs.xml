<?xml version="1.0"?>
<ruleset name="Notification Hub">
	<description>WordPress Coding Standards for Notification Hub</description>

	<!-- Include WordPress standards -->
	<rule ref="WordPress-Core"/>
	<rule ref="WordPress-Docs"/>
	<rule ref="WordPress-Extra"/>

	<!-- Check all PHP files -->
	<arg name="extensions" value="php"/>

	<!-- Show progress -->
	<arg value="ps"/>

	<!-- Strip path prefix -->
	<arg name="basepath" value="."/>

	<!-- Check src folder -->
	<file>src/</file>

	<!-- Exclude vendor -->
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>

	<!-- Text domain -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array" value="notification-hub"/>
		</properties>
	</rule>

	<!-- Prefix check -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array" value="nh,Notification_Hub"/>
		</properties>
	</rule>
</ruleset>
